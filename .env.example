# Convex Scientist — frontend environment template.
# Copy to `.env.local`. The Convex values below are written automatically the
# first time you run `npx convex dev` — you normally don't edit them by hand.
#
# Server-side secrets (ANTHROPIC_API_KEY, auth keys, sandbox tokens) do NOT go
# here — they live on the Convex deployment. See docs/SETUP.md.

# Convex deployment this checkout is linked to (set by `npx convex dev`).
CONVEX_DEPLOYMENT=

# Public Convex URLs the browser talks to (set by `npx convex dev`).
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
