# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep a committed template for contributors (open-source, BYO API key)
!.env.example

# vercel
.vercel

# AI Scientist / Convex quickstart — never commit these
# generated JWT private key + JWKS (A0 auth setup)
.auth-keys.json
# bootstrap log / lock / domains brainstorm
.quickstart-*
# downloaded at publish time, not source
publish-convex-app.mjs
# stray local logs (error mirrors live in a temp dir)
*.log

# typescript
*.tsbuildinfo
next-env.d.ts

# local Claude Code tooling config
.claude/
